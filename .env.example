# QMail Configuration Template
# Copy this file to .env and fill in your values.
# DO NOT commit your real .env file - it is gitignored.

# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
# Generate a strong secret key, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-long-random-hex-string

# Database
# Local SQLite (default):
DATABASE_URL=sqlite:///qmail.db
# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/qmail

# Quantum Key Manager Configuration
QKD_KM_HOST=localhost
QKD_KM_PORT=8080
QKD_KM_API_VERSION=v1
QKD_KM_MASTER_SAE_ID=your-master-sae-id
QKD_KM_SLAVE_SAE_ID=your-slave-sae-id
QKD_KM_USE_HTTPS=false
QKD_KM_VERIFY_SSL=true

# Email Server Configuration (for sending)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true

# Email Server Configuration (for receiving)
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
IMAP_USE_SSL=true

# Default Security Level (1-4)
# 1: Quantum Secure (OTP), 2: Quantum-Aided AES, 3: PQC, 4: Classical
DEFAULT_SECURITY_LEVEL=2

# Logging
LOG_LEVEL=INFO
LOG_FILE=qmail.log

# Application Settings
MAX_EMAIL_SIZE=25  # MB
SESSION_TIMEOUT=30  # minutes

# Default Admin Account
# A default admin user is auto-created on first boot using these values.
# CHANGE THE PASSWORD before going to production, or set
# DEFAULT_ADMIN_DISABLE=true to skip seeding entirely.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin
DEFAULT_ADMIN_EMAIL=admin@qmail.local
DEFAULT_ADMIN_DISABLE=false
